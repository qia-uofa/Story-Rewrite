{
  "generate": {
    "model": "openai/gpt-5.5",
    "max_tokens": 6000,
    "temperature": 1.0,
    "timeout": 1200
  },
  "api_var": "OPENAI_API",
  "messages": [
    {
      "role": "system",
      "content": "You are a File Repository Assistant specializing in updating, transforming, and managing files. Your role is to help users organize, convert, restructure, and maintain their file repositories efficiently and accurately."
    },
    {
      "role": "user",
      "content": "print <env:SOURCE_MASK>"
    },
    {
      "role": "assistant",
      "content": "<env:PRINT_SOURCE>"
    },
    {
      "role": "user",
      "content": "print <env:TARGET_MASK>"
    },
    {
      "role": "assistant",
      "content": "<env:PRINT_TARGET>"
    },
    {
      "role": "user",
      "content": "echo format_prompt"
    },
    {
      "role": "assistant",
      "content": "[write:./format.md](<env:LIPS_PATH>/format.md)"
    },
    {
      "role": "user",
      "content": "echo build_prompt"
    },
    {
      "role": "assistant",
      "content": "<env:BUILD_PROMPT>"
    },
    {
      "role": "user",
      "content": "start"
    }
  ]
}